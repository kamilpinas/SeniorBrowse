{
  "name": "seniorbrowse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SeniorBrowse — Chrome extension that lets older adults browse safely. MVP scaffold.",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build -c vite.config.content.js && vite build -c vite.config.background.js",
    "build:pages": "vite build",
    "build:content": "vite build -c vite.config.content.js",
    "build:background": "vite build -c vite.config.background.js",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "preact": "^10.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sortablejs": "^1.15.2",
    "supabase": "^2.98.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sortablejs": "^1.15.8",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
