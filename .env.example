# Copy this file to .env and fill in your values.
# Vite injects VITE_* variables at build time (available in extension code).

# Google Safe Browsing API v4 key
# Obtain from: https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
# Leave blank to disable safe-browsing checks (development only).
VITE_SAFE_BROWSING_KEY=

# Supabase — get these from supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Lemon Squeezy — get from lemonsqueezy.com → Settings → API
# STORE_ID: your numeric store ID (shown in the URL when viewing your store)
# WEBHOOK_SECRET: set when creating the webhook in LS dashboard
VITE_LEMON_SQUEEZY_STORE_ID=
VITE_LEMON_SQUEEZY_MONTHLY_VARIANT_ID=
VITE_LEMON_SQUEEZY_YEARLY_VARIANT_ID=
