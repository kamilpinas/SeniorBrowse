# Copy this file to .env and fill in your values.
# Vite injects VITE_* variables at build time. ANYTHING prefixed VITE_ is
# bundled into the extension and is therefore PUBLIC. Never put a secret here.

# NOTE: The Google Safe Browsing API key is NOT a client variable. It lives
# only in Supabase as the `SAFE_BROWSING_KEY` edge-function secret and is
# proxied by the check-url function, so it is never shipped in the bundle.
# Set it with:  supabase secrets set SAFE_BROWSING_KEY=your-key

# Supabase — get these from supabase.com → your project → Settings → API
# The anon key is public by design; the licenses table is protected by RLS
# (see supabase/migrations/20260611_lock_down_licenses_rls.sql).
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Lemon Squeezy — get from lemonsqueezy.com → Settings → API
# STORE_ID: your numeric store ID (shown in the URL when viewing your store)
# WEBHOOK_SECRET: set when creating the webhook in LS dashboard
VITE_LEMON_SQUEEZY_STORE_ID=
VITE_LEMON_SQUEEZY_MONTHLY_VARIANT_ID=
VITE_LEMON_SQUEEZY_YEARLY_VARIANT_ID=
