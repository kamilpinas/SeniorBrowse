{
  "manifest_version": 3,
  "name": "SeniorBrowse",
  "version": "1.0.0",
  "description": "Browse the internet without fear. Simple interface, big buttons, no surprises.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "downloads",
    "declarativeNetRequest",
    "scripting",
    "webNavigation",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "chrome_url_overrides": {
    "newtab": "newtab/index.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "css": ["content/panel.css"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "action": {
    "default_title": "SeniorBrowse — open panel",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "Alt+Shift+P"
      },
      "description": "Open / close the SeniorBrowse panel"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ad_block_rules",
        "enabled": false,
        "path": "rules/ad-rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "warn.html", "newtab/index.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
